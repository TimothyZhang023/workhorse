{
  "name": "gemini-chat-unified",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "max dev",
    "dev:server": "node server.js",
