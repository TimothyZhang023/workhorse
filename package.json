{
  "name": "workhorse",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:facade": "vite",
    "dev:gateway": "PORT=12621 node server.js",
    "dev": "npm run stop && concurrently --kill-others --handle-input -n \"gateway,facade\" -c \"blue,green\" \"npm run dev:gateway\" \"npm run dev:facade\"",
    "dev:tauri": "npm run stop && tauri dev",
    "tauri": "tauri",
    "stop": "node scripts/killport.mjs 12620 12621",
    "restart": "npm run stop && npm run dev",
    "build": "npm run build:facade",
    "build:frontend": "npm run build:facade",
    "build:facade": "vite build",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "build:dmg": "node scripts/build-dmg.mjs",
    "build:tauri": "npm run build:sidecar && tauri build --bundles app && npm run build:dmg",
    "release": "npm version patch && git push && git push --tags",
    "start": "PORT=12621 node server.js",
    "format": "prettier --write .",
    "prepare": "husky install",
    "test": "vitest run",
    "test:ci": "vitest run --coverage.enabled=false",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ant-design/icons": "^5.0.1",
    "@ant-design/pro-components": "^2.4.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "antd": "^5.4.0",
    "better-sqlite3": "^12.6.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "openai": "^4.20.0",
    "pino": "^9.0.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^8.0.7",
    "react-router-dom": "^6.20.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^3.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vercel/ncc": "^0.38.4",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "husky": "^8.0.3",
    "postcss": "^8.5.6",
    "prettier": "^2.8.7",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0",
    "vite": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "pkg": {
    "assets": [
      "node_modules/@modelcontextprotocol/sdk/**/*",
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node"
    ]
  }
}
