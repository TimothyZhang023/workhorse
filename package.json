    "@ant-design/pro-components": "^2.4.4",
    "@umijs/max": "^4.0.0",
    "antd": "^5.4.0",
    "better-sqlite3": "^12.6.2",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^4.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^8.0.7",
    "remark-gfm": "^3.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "autoprefixer": "^10.4.24",
    "husky": "^8.0.3",
    "postcss": "^8.5.6",
    "prettier": "^2.8.7",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0"
