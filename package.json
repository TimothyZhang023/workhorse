{
  "name": "cowhouse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "max build",
    "dev": "concurrently -n \"server,client\" -c \"blue,green\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "PORT=8000 max dev",
    "dev:server": "PORT=8080 node server.js",
    "format": "prettier --write .",
    "postinstall": "max setup",
    "prepare": "husky install",
    "restart": "npm run stop && npm run dev",
    "restart:prod": "npm run stop && npm run start:prod",
    "start": "node server.js",
    "start:prod": "npm run build && npm run start",
    "stop": "kill-port 8000 8080",
    "test": "vitest run",
    "test:ci": "vitest run --coverage.enabled=false",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ant-design/icons": "^5.0.1",
    "@ant-design/pro-components": "^2.4.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@umijs/max": "^4.0.0",
    "antd": "^5.4.0",
    "better-sqlite3": "^12.6.2",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "openai": "^4.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^8.0.7",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^3.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "autoprefixer": "^10.4.24",
    "husky": "^8.0.3",
    "kill-port": "^2.0.1",
    "postcss": "^8.5.6",
    "prettier": "^2.8.7",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
