{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "workhorse",
  "version": "2.0.1",
  "identifier": "com.workhorse.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:12620",
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npx vite build"
  },
  "app": {
    "windows": [
      {
        "title": "workhorse",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["workhorse"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["sidecar-runtime/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowPosition": {
          "x": 400,
          "y": 400
        },
        "windowSize": {
          "width": 540,
          "height": 380
        },
        "appPosition": {
          "x": 130,
          "y": 150
        },
        "applicationFolderPosition": {
          "x": 410,
          "y": 150
        }
      }
    }
  }
}
